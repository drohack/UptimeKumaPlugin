<?php
$plugin = "uptime-kuma";
$cfgfile = "/boot/config/plugins/{$plugin}/uptime-kuma.cfg";

if (!file_exists($cfgfile)) return;
$cfg = parse_ini_file($cfgfile);
if (($cfg['SERVICE'] ?? 'disable') !== 'enable') return;
?>

<tbody title="Uptime Kuma" sort="<?=md5('Uptime Kuma')?>">
    <tr>
        <td>
            <span class='tile-header'>
                <span class='tile-header-left'>
                    <i class='icon-uptime-kuma f32'></i>
                    <div class='section'>
                        <h3 class='tile-header-main'>Uptime Kuma</h3>
                        <span id='uk-summary'>Loading...</span>
                    </div>
                </span>
                <span class='tile-header-right'>
                    <span class='tile-header-right-controls'>
                        <select id='uk-period-select' class='uk-period-dropdown'>
                            <option value='1h'>1 Hour</option>
                            <option value='12h'>12 Hours</option>
                            <option value='24h' selected>24 Hours</option>
                            <option value='7d'>7 Days</option>
                            <option value='30d'>30 Days</option>
                            <option value='90d'>90 Days</option>
                            <option value='180d'>180 Days</option>
                        </select>
                        <a href='/Settings/UptimeKumaSettings' title='Uptime Kuma Settings'><i class='fa fa-fw fa-cog control'></i></a>
                        <i class='fa fa-fw fa-chevron-up control openclose' onclick='openClose($(this))' title='Toggle'></i>
                    </span>
                </span>
            </span>
        </td>
    </tr>
    <tr>
        <td>
            <div id='uk-monitors'>
                <div class='uk-loading'><i class='fa fa-spinner fa-spin'></i> Loading monitors...</div>
            </div>
        </td>
    </tr>
</tbody>

<link rel='stylesheet' href='/plugins/uptime-kuma/css/uptime-kuma.css'>
<script src='/plugins/uptime-kuma/scripts/uptime-kuma.js'></script>
<script>
uptimeKumaInit(<?=json_encode([
    'refreshInterval' => (int)($cfg['REFRESHINTERVAL'] ?? 30),
    'maxMonitors'     => (int)($cfg['MAXMONITORS'] ?? 5),
    'defaultPeriod'   => $cfg['DEFAULTPERIOD'] ?? '24h',
])?>);
</script>
