<?php
$plugin = "uptime-kuma";
$cfgfile = "/boot/config/plugins/{$plugin}/uptime-kuma.cfg";
$defaultcfg = "/usr/local/emhttp/plugins/{$plugin}/default.cfg";

// Create config from defaults if it doesn't exist
if (!file_exists($cfgfile)) {
    @mkdir(dirname($cfgfile), 0755, true);
    @copy($defaultcfg, $cfgfile);
}

$cfg = parse_ini_file($cfgfile);
?>

<link rel="stylesheet" href="/plugins/uptime-kuma/css/uptime-kuma.css">

<div id="uk-settings">
    <div class="title"><span class="left">Uptime Kuma Settings</span></div>

    <form method="POST" action="/update.php" target="progressFrame" id="uk-settings-form">
        <input type="hidden" name="#file" value="uptime-kuma/uptime-kuma.cfg">
        <input type="hidden" name="#command" value="">

        <table class="tablesorter shift ups">
            <thead>
                <tr><th colspan="2">General Settings</th></tr>
            </thead>
            <tbody>
                <tr>
                    <td>Enable Dashboard Widget:</td>
                    <td>
                        <select name="SERVICE">
                            <option value="disable" <?= ($cfg['SERVICE'] ?? '') === 'disable' ? 'selected' : '' ?>>Disabled</option>
                            <option value="enable" <?= ($cfg['SERVICE'] ?? '') === 'enable' ? 'selected' : '' ?>>Enabled</option>
                        </select>
                    </td>
                </tr>
                <tr>
                    <td>Database Path:</td>
                    <td>
                        <input type="text" name="DBPATH" value="<?= htmlspecialchars($cfg['DBPATH'] ?? '') ?>"
                               placeholder="/mnt/user/appdata/uptimekuma/kuma.db" size="60">
                        <button type="button" class="uk-btn" onclick="uptimeKumaTestConnection()">Test Connection</button>
                        <span id="uk-test-result"></span>
                        <p class="uk-help-text">
                            Path to Uptime Kuma's SQLite database file on the Unraid filesystem.<br>
                            Typically found at <code>/mnt/user/appdata/uptimekuma/kuma.db</code>.<br>
                            Check your Docker container's volume mappings if unsure.
                        </p>
                    </td>
                </tr>
            </tbody>
        </table>

        <table class="tablesorter shift ups">
            <thead>
                <tr><th colspan="2">Display Settings</th></tr>
            </thead>
            <tbody>
                <tr>
                    <td>Refresh Interval:</td>
                    <td>
                        <select name="REFRESHINTERVAL">
                            <?php
                            $intervals = ['10' => '10 seconds', '15' => '15 seconds', '30' => '30 seconds', '60' => '1 minute', '120' => '2 minutes'];
                            foreach ($intervals as $val => $label):
                            ?>
                                <option value="<?= $val ?>" <?= ($cfg['REFRESHINTERVAL'] ?? '30') === $val ? 'selected' : '' ?>><?= $label ?></option>
                            <?php endforeach; ?>
                        </select>
                    </td>
                </tr>
                <tr>
                    <td>Max Monitors to Display:</td>
                    <td>
                        <input type="number" name="MAXMONITORS" value="<?= htmlspecialchars($cfg['MAXMONITORS'] ?? '50') ?>"
                               min="1" max="200" size="5">
                    </td>
                </tr>
                <tr>
                    <td>Default Time Period:</td>
                    <td>
                        <select name="DEFAULTPERIOD">
                            <?php
                            $periodOptions = ['1h' => '1 Hour', '12h' => '12 Hours', '24h' => '24 Hours', '7d' => '7 Days', '30d' => '30 Days', '90d' => '90 Days', '180d' => '180 Days'];
                            foreach ($periodOptions as $val => $label):
                            ?>
                                <option value="<?= $val ?>" <?= ($cfg['DEFAULTPERIOD'] ?? '24h') === $val ? 'selected' : '' ?>><?= $label ?></option>
                            <?php endforeach; ?>
                        </select>
                    </td>
                </tr>
            </tbody>
        </table>

        <div class="uk-buttons">
            <input type="submit" value="Apply" id="uk-apply-btn">
            <input type="button" value="Done" onclick="done()">
            <input type="button" value="Reset" onclick="resetForm()">
        </div>
    </form>
</div>

<script>
function uptimeKumaTestConnection() {
    var dbpath = document.querySelector('input[name="DBPATH"]').value;
    var resultEl = document.getElementById('uk-test-result');
    resultEl.innerHTML = '<span style="color:#ff9800;">Testing...</span>';

    // We pass the dbpath as a query parameter for testing before saving
    $.getJSON('/plugins/uptime-kuma/UptimeKumaData.php', { action: 'test', dbpath: dbpath }, function(data) {
        if (data.success) {
            resultEl.innerHTML = '<span style="color:#4caf50;">' + escapeHtml(data.message) + '</span>';
        } else {
            resultEl.innerHTML = '<span style="color:#f44336;">' + escapeHtml(data.error) + '</span>';
        }
    }).fail(function() {
        resultEl.innerHTML = '<span style="color:#f44336;">Failed to reach plugin backend.</span>';
    });
}

function resetForm() {
    document.getElementById('uk-settings-form').reset();
}

function escapeHtml(text) {
    var div = document.createElement('div');
    div.appendChild(document.createTextNode(text));
    return div.innerHTML;
}
</script>
