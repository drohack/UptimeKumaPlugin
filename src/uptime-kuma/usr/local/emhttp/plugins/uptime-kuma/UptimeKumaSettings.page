<script>
var ukSelectedMonitors = <?= json_encode($selectedMonitors) ?>;

$(function() {
    uptimeKumaLoadMonitors();
});

function uptimeKumaTestConnection() {
    var dbpath = document.querySelector('input[name="DBPATH"]').value;
    var resultEl = document.getElementById('uk-test-result');
    resultEl.innerHTML = '<span style="color:#ff9800;">Testing...</span>';

    $.getJSON('/plugins/uptime-kuma/UptimeKumaData.php', { action: 'test', dbpath: dbpath }, function(data) {
        if (data.success) {
            resultEl.innerHTML = '<span style="color:#4caf50;">' + escapeHtml(data.message) + '</span>';
            // Reload monitor list after successful connection test
            uptimeKumaLoadMonitors();
        } else {
            resultEl.innerHTML = '<span style="color:#f44336;">' + escapeHtml(data.error) + '</span>';
        }
    }).fail(function() {
        resultEl.innerHTML = '<span style="color:#f44336;">Failed to reach plugin backend.</span>';
    });
}

function uptimeKumaDetectWebUI() {
    var resultEl = document.getElementById('uk-webui-result');
    resultEl.innerHTML = '<span style="color:#ff9800;">Detecting...</span>';

    $.getJSON('/plugins/uptime-kuma/UptimeKumaData.php', { action: 'webui' }, function(data) {
        if (data.webui) {
            document.getElementById('uk-webui').value = data.webui;
            resultEl.innerHTML = '<span style="color:#4caf50;">Found: ' + escapeHtml(data.webui) + '</span>';
        } else {
            resultEl.innerHTML = '<span style="color:#f44336;">Could not auto-detect. Please enter manually.</span>';
        }
    }).fail(function() {
        resultEl.innerHTML = '<span style="color:#f44336;">Failed to reach plugin backend.</span>';
    });
}

function uptimeKumaLoadMonitors() {
    var container = document.getElementById('uk-monitor-list');
    $.getJSON('/plugins/uptime-kuma/UptimeKumaData.php', { action: 'list' }, function(data) {
        if (data.error) {
            container.innerHTML = '<em style="color:#888;">Configure database path first, then click Test Connection.</em>';
            return;
        }
        if (!data.monitors || data.monitors.length === 0) {
            container.innerHTML = '<em>No monitors found.</em>';
            return;
        }

        var html = '';
        data.monitors.forEach(function(m) {
            var checked = (ukSelectedMonitors.length === 0 || ukSelectedMonitors.indexOf(String(m.id)) !== -1) ? 'checked' : '';
            var activeLabel = m.active ? '' : ' <span style="color:#888;">(inactive)</span>';
            html += '<label class="uk-monitor-checkbox">';
            html += '<input type="checkbox" value="' + m.id + '" ' + checked + ' onchange="uptimeKumaUpdateMonitors()"> ';
            html += escapeHtml(m.name) + activeLabel;
            html += '</label><br>';
        });
        container.innerHTML = html;
    }).fail(function() {
        container.innerHTML = '<em style="color:#888;">Configure database path first.</em>';
    });
}

function uptimeKumaUpdateMonitors() {
    var checkboxes = document.querySelectorAll('#uk-monitor-list input[type="checkbox"]');
    var allChecked = true;
    var ids = [];
    checkboxes.forEach(function(cb) {
        if (cb.checked) {
            ids.push(cb.value);
        } else {
            allChecked = false;
        }
    });
    // If all are checked, store empty string (means "show all")
    document.getElementById('uk-monitors-value').value = allChecked ? '' : ids.join(',');
}

function resetForm() {
    document.getElementById('uk-settings-form').reset();
    uptimeKumaLoadMonitors();
}

function escapeHtml(text) {
    var div = document.createElement('div');
    div.appendChild(document.createTextNode(text));
    return div.innerHTML;
}
</script>
