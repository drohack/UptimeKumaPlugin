    @mkdir(dirname($cfgfile), 0755, true);
    @copy($defaultcfg, $cfgfile);
}

$cfg = parse_ini_file($cfgfile);
$selectedMonitors = array_filter(explode(',', $cfg['MONITORS'] ?? ''));
?>

